<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="com.itwillbs.mapper.SupplierItemMapper">

  <resultMap id="supplierItemMap" type="com.itwillbs.domain.SupplierItemVO">
	  <id property="id" column="id"/>
	  <result property="supplierId" column="supplier_id"/>
	  <result property="materialId" column="material_id"/>
	  <result property="materialName" column="material_name"/>
	  <result property="materialType" column="material_type"/>
	  <result property="unitPrice" column="unit_price"/>
	  <result property="unit" column="unit"/>
	  <result property="supplyAvailable" column="supply_available"/>
	  <result property="note" column="note"/>
	  <result property="createdAt" column="created_at"/>
	  <result property="updatedAt" column="updated_at"/>
  </resultMap>
  	

  <!-- 특정 협력사가 공급하는 자재 목록 조회 - supplier_item + material 조인 -->
  <select id="selectSuppliedItemsBySupplierId" resultMap="supplierItemMap">
    SELECT 
      si.*, 
      m.material_name, 
      m.material_type
    FROM supplier_item si
    JOIN material m ON si.material_id = m.material_id
    WHERE si.supplier_id = #{supplierId}
  </select>

</mapper>